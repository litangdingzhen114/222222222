# Application
NODE_ENV=development
HOST=0.0.0.0
PORT=8787
PUBLIC_BASE_URL=http://127.0.0.1:8787
ALLOWED_ORIGINS=http://127.0.0.1:8787,http://127.0.0.1:5173
TRUST_PROXY=false
SWAGGER_ENABLED=true
LOG_LEVEL=info

# PostgreSQL / Redis
DATABASE_URL=postgresql://hailin:hailin_dev_password@127.0.0.1:5432/hailin?schema=public
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_REQUIRED=false

# JWT - production secrets must be at least 32 random characters
JWT_ACCESS_SECRET=development-access-secret-change-before-production
JWT_REFRESH_SECRET=development-refresh-secret-change-before-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Initial administrator. Seed refuses a weak production password.
SEED_ADMIN_USERNAME=hailin-admin
SEED_ADMIN_PASSWORD=ChangeMe-Only-For-Local-2026
SEED_ADMIN_DISPLAY_NAME=海林村超级管理员

# WeChat Mini Program - waiting for official credentials
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_API_BASE_URL=https://api.weixin.qq.com
WECHAT_MOCK_ENABLED=true

# WeChat Pay API v3 - waiting for official credentials
WECHAT_PAY_APP_ID=
WECHAT_PAY_MCH_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=
WECHAT_PAY_PLATFORM_CERT_PATH=
WECHAT_PAY_NOTIFY_URL=
WECHAT_PAY_API_BASE_URL=https://api.mch.weixin.qq.com

# AMap - waiting for official credentials
AMAP_KEY=
AMAP_API_BASE_URL=https://restapi.amap.com

# Ezviz - waiting for official credentials
EZVIZ_APP_KEY=
EZVIZ_APP_SECRET=
EZVIZ_API_BASE_URL=https://open.ys7.com/api/lapp
EZVIZ_MOCK_ENABLED=true

# Storage: local or cos
STORAGE_DRIVER=local
LOCAL_UPLOAD_DIR=uploads
UPLOAD_PUBLIC_PREFIX=/uploads
UPLOAD_MAX_FILE_SIZE=5242880
UPLOAD_MAX_FILES=9
TENCENT_COS_SECRET_ID=
TENCENT_COS_SECRET_KEY=
TENCENT_COS_BUCKET=
TENCENT_COS_REGION=
TENCENT_COS_PUBLIC_BASE_URL=

# OpenAI-compatible LLM provider - waiting for official credentials
LLM_PROVIDER=kimi
LLM_API_KEY=
LLM_BASE_URL=https://api.moonshot.cn/v1
LLM_MODEL=kimi-k2.5
LLM_TIMEOUT_MS=12000

# Business limits
MAX_PAGE_SIZE=100
MAP_MAX_RADIUS_METERS=20000
ORDER_PAYMENT_TIMEOUT_MINUTES=30
RESERVATION_PAYMENT_TIMEOUT_MINUTES=30
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_LIMIT=120
LOGIN_RATE_LIMIT_LIMIT=10
PLAY_URL_RATE_LIMIT_LIMIT=20
