.route-detail-page {
  padding-bottom: 142rpx;
  background: #EEF6F4;
}

.route-cover-large {
  position: relative;
  min-height: 320rpx;
  overflow: hidden;
  border-radius: 0;
}

.route-cover-large::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1;
  background: rgba(8, 43, 42, 0.34);
}

.route-cover-photo {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.route-cover-copy {
  position: relative;
  z-index: 2;
  width: 610rpx;
  padding: 64rpx 34rpx 0;
  color: #FBFFFC;
}

.route-cover-title {
  font-size: 42rpx;
  font-weight: 800;
  line-height: 1.15;
}

.route-cover-sub {
  margin-top: 16rpx;
  color: rgba(255, 253, 248, 0.9);
  font-size: 26rpx;
  line-height: 1.5;
}

.route-cover-word {
  display: none;
}

.route-detail-content {
  padding: 24rpx;
}

.route-info-card,
.timeline-card {
  padding: 26rpx;
}

.timeline-card {
  margin-top: 22rpx;
}

.included-card,
.prepare-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.info-title {
  color: #0F6B67;
  font-size: 30rpx;
  font-weight: 800;
}

.info-desc {
  margin-top: 14rpx;
  color: #5B422B;
  font-size: 27rpx;
  line-height: 1.65;
}

.route-info-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 24rpx;
}

.route-info-grid view {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #EEF6F4;
}

.included-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.included-item {
  min-height: 78rpx;
  padding: 18rpx;
  border-radius: 12rpx;
  background: #EEF6F4;
  color: #193C3A;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1.45;
}

.prepare-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 18rpx;
  color: #5B422B;
  font-size: 25rpx;
  line-height: 1.55;
}

.prepare-row text {
  flex-shrink: 0;
  width: 10rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #C89C3F;
}

.grid-label {
  color: #607F7A;
  font-size: 24rpx;
}

.grid-value {
  color: #193C3A;
  font-size: 25rpx;
  font-weight: 800;
}

.timeline {
  margin-top: 24rpx;
}

.timeline-item {
  position: relative;
  display: grid;
  grid-template-columns: 94rpx 34rpx 1fr;
  min-height: 118rpx;
}

.timeline-item::after {
  content: "";
  position: absolute;
  left: 108rpx;
  top: 30rpx;
  bottom: -10rpx;
  width: 2rpx;
  background: #DCEDEA;
}

.timeline-item:last-child::after {
  display: none;
}

.timeline-time {
  color: #1D7C78;
  font-size: 24rpx;
  font-weight: 900;
}

.timeline-dot {
  position: relative;
  z-index: 2;
  width: 20rpx;
  height: 20rpx;
  margin-top: 8rpx;
  border: 4rpx solid #BFD9D3;
  border-radius: 50%;
  background: #0F6B67;
}

.timeline-title {
  color: #193C3A;
  font-size: 28rpx;
  font-weight: 900;
}

.timeline-desc {
  margin-top: 8rpx;
  color: #315A4E;
  font-size: 24rpx;
  line-height: 1.45;
}

.route-bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  gap: 18rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #FBFFFC;
  box-shadow: 0 -10rpx 28rpx rgba(112, 76, 34, 0.08);
}

.route-fav {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 170rpx;
  height: 78rpx;
  border-radius: 14rpx;
  background: #F6E8D2;
  color: #0F6B67;
  font-size: 27rpx;
  font-weight: 900;
}

.route-fav.active {
  background: #BFD9D3;
}

.route-start {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  border-radius: 14rpx;
  background: #0F6B67;
  color: #FBFFFC;
  font-size: 28rpx;
  font-weight: 900;
}
