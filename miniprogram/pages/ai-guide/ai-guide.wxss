.ai-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #EEF6F4;
}

.ai-head {
  padding: 24rpx 26rpx 18rpx;
}

.ai-title {
  color: #0F4F4B;
  font-size: 40rpx;
  font-weight: 900;
}

.ai-subtitle {
  margin-top: 8rpx;
  color: #607F7A;
  font-size: 24rpx;
}

.chat-list {
  flex: 1;
  min-height: 0;
  padding: 8rpx 24rpx 24rpx;
}

.message-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-bottom: 22rpx;
}

.message-row.user {
  flex-direction: row-reverse;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
  background: #BFD9D3;
  color: #0F4F4B;
  font-size: 22rpx;
  font-weight: 900;
}

.message-row.user .avatar {
  background: #0F6B67;
  color: #FBFFFC;
}

.message-bubble {
  max-width: 560rpx;
  padding: 18rpx 22rpx;
  border-radius: 24rpx;
  background: #FBFFFC;
  color: #193C3A;
  font-size: 27rpx;
  line-height: 1.55;
  box-shadow: 0 10rpx 24rpx rgba(26, 74, 70, 0.06);
}

.message-row.user .message-bubble {
  background: linear-gradient(135deg, #1D7C78, #0F4F4B);
  color: #FBFFFC;
}

.source-tag {
  display: inline-flex;
  margin-bottom: 8rpx;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #E2F0EC;
  color: #0F6B67;
  font-size: 19rpx;
  font-weight: 800;
}

.source-tag.backend {
  background: #E8F4F1;
  color: #0F6B67;
}

.source-tag.loading {
  background: #F4E9DA;
  color: #A7472D;
}

.quick-row {
  display: flex;
  gap: 12rpx;
  overflow-x: auto;
  padding: 14rpx 24rpx;
  white-space: nowrap;
}

.quick-chip {
  flex: 0 0 auto;
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #DCEDEA;
  color: #0F4F4B;
  font-size: 24rpx;
  font-weight: 700;
}

.input-bar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 16rpx 24rpx calc(16rpx + env(safe-area-inset-bottom));
  background: #FBFFFC;
  box-shadow: 0 -8rpx 24rpx rgba(26, 74, 70, 0.08);
}

.input-bar input {
  flex: 1;
  height: 76rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: #EEF6F4;
  color: #193C3A;
  font-size: 26rpx;
}

.input-placeholder {
  color: #8EA6A0;
}

.send-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1D7C78, #0F4F4B);
  color: #FBFFFC;
  font-size: 26rpx;
  font-weight: 900;
}

.send-btn.disabled {
  opacity: 0.62;
}
