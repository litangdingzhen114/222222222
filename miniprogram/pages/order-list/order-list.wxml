<view class="page page-pad order-list-page">
  <view class="order-hero">
    <view class="order-title">我的订单</view>
    <view class="order-sub">查看预约、票券、文创商品和服务履约进度</view>
  </view>

  <view class="summary-grid">
    <view class="summary-card">
      <view class="summary-value">{{summary.total}}</view>
      <view class="summary-label">全部订单</view>
    </view>
    <view class="summary-card">
      <view class="summary-value">{{summary.active}}</view>
      <view class="summary-label">进行中</view>
    </view>
    <view class="summary-card">
      <view class="summary-value">{{summary.shipping}}</view>
      <view class="summary-label">物流相关</view>
    </view>
  </view>

  <scroll-view class="filter-scroll" scroll-x>
    <view class="filter-row">
      <view
        wx:for="{{statusFilters}}"
        wx:key="value"
        class="filter-chip {{activeStatus === item.value ? 'active' : ''}}"
        data-status="{{item.value}}"
        bindtap="onFilterTap"
      >{{item.label}}</view>
    </view>
  </scroll-view>

  <view wx:if="{{filteredOrders.length}}" class="order-list">
    <view wx:for="{{filteredOrders}}" wx:key="id" class="order-card card" data-id="{{item.id}}" bindtap="onOrderTap">
      <view class="order-card-head">
        <view>
          <view class="order-name">{{item.title}}</view>
          <view class="order-no">{{item.orderNo || item.id}}</view>
        </view>
        <view class="order-status {{item.statusClass}}">{{item.statusText}}</view>
      </view>
      <view class="order-meta">
        <text>{{item.typeText}}</text>
        <text>{{item.dateText}}</text>
        <text>{{item.peopleText}}</text>
      </view>
      <view class="order-desc">{{item.descText}}</view>
      <view class="order-card-foot">
        <text>查看履约详情</text>
        <text class="foot-arrow">›</text>
      </view>
    </view>
  </view>

  <view wx:elif="{{!loading}}" class="empty-card">
    <view class="empty-title">还没有订单</view>
    <view class="empty-desc">预约讲解、购买文创或报名活动后，订单会出现在这里。</view>
    <button class="empty-action" bindtap="onExploreTap">去预约村游服务</button>
  </view>
</view>
