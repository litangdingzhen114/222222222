.order-list-page {
  background: #eef6f4;
}

.order-hero {
  padding: 28rpx;
  border-radius: 20rpx;
  color: #ffffff;
  background: linear-gradient(135deg, #0f6b67, #4d8f74);
}

.order-title {
  font-size: 42rpx;
  font-weight: 800;
}

.order-sub {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.82);
  font-size: 24rpx;
}

.filter-scroll {
  margin: 24rpx 0;
  white-space: nowrap;
}

.filter-row {
  display: flex;
  gap: 16rpx;
}

.filter-chip {
  flex: 0 0 auto;
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  color: #4f6d68;
  background: #ffffff;
  font-size: 24rpx;
}

.filter-chip.active {
  color: #ffffff;
  background: #0f6b67;
}

.order-list {
  display: grid;
  gap: 18rpx;
}

.order-card {
  padding: 24rpx;
}

.order-card-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.order-name {
  color: #173c38;
  font-size: 30rpx;
  font-weight: 800;
}

.order-no {
  margin-top: 6rpx;
  color: #78908c;
  font-size: 22rpx;
}

.order-status {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  color: #0f6b67;
  background: #e3f2ee;
  font-size: 22rpx;
  font-weight: 700;
}

.order-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
  color: #607b76;
  font-size: 23rpx;
}

.order-desc {
  margin-top: 14rpx;
  color: #34534e;
  font-size: 24rpx;
  line-height: 1.6;
}
