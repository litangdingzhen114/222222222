.feedback-hero {
  min-height: 210rpx;
  padding: 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid #DCEDEA;
  border-left: 10rpx solid #0F6B67;
  background: #FBFFFC;
  color: #193C3A;
}

.feedback-title {
  font-size: 38rpx;
  font-weight: 800;
}

.feedback-desc {
  margin-top: 16rpx;
  color: #607F7A;
  font-size: 26rpx;
  line-height: 1.55;
}

.promise-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
  margin-top: 22rpx;
}

.promise-card {
  min-height: 142rpx;
  padding: 18rpx;
  border-radius: 14rpx;
  background: #FBFFFC;
  box-shadow: 0 6rpx 18rpx rgba(26, 74, 70, 0.05);
}

.promise-title {
  color: #193C3A;
  font-size: 25rpx;
  font-weight: 900;
}

.promise-desc {
  margin-top: 8rpx;
  color: #607F7A;
  font-size: 21rpx;
  line-height: 1.45;
}

.feedback-card {
  margin-top: 22rpx;
  padding: 28rpx;
}

.field-title {
  margin: 10rpx 0 18rpx;
  color: #193C3A;
  font-size: 29rpx;
  font-weight: 900;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
  margin-bottom: 30rpx;
}

.type-item {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 72rpx;
  border-radius: 10rpx;
  background: #EEF6F4;
  color: #607F7A;
  font-size: 25rpx;
  font-weight: 700;
}

.type-item.active {
  background: #BFD9D3;
  color: #0F6B67;
}

.example-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin: -4rpx 0 18rpx;
}

.example-row text {
  padding: 8rpx 14rpx;
  border-radius: 8rpx;
  background: #F9F2E6;
  color: #5B422B;
  font-size: 22rpx;
  font-weight: 700;
}

.feedback-textarea {
  width: 100%;
  min-height: 260rpx;
  padding: 22rpx;
  border-radius: 10rpx;
  background: #EEF6F4;
  color: #193C3A;
  font-size: 27rpx;
  line-height: 1.55;
}

.feedback-input {
  height: 82rpx;
  padding: 0 22rpx;
  border-radius: 10rpx;
  background: #EEF6F4;
  color: #193C3A;
  font-size: 27rpx;
}

.feedback-placeholder {
  color: #8EA6A0;
}

.feedback-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 86rpx;
  margin-top: 32rpx;
  border-radius: 14rpx;
  background: #0F6B67;
  color: #FBFFFC;
  font-size: 29rpx;
  font-weight: 900;
}
