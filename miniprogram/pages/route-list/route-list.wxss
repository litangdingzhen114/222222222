.route-hero {
  min-height: 220rpx;
  padding: 34rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #0F6B67 0%, #1D7C78 54%, #BFD9D3 100%);
  color: #FBFFFC;
  box-shadow: 0 18rpx 44rpx rgba(154, 91, 31, 0.18);
}

.route-hero-title {
  font-size: 48rpx;
  font-weight: 900;
}

.route-hero-subtitle {
  width: 520rpx;
  margin-top: 18rpx;
  color: rgba(255, 253, 248, 0.9);
  font-size: 26rpx;
  line-height: 1.55;
}

.route-list {
  margin-top: 24rpx;
}

.route-card {
  display: flex;
  gap: 20rpx;
  margin-bottom: 22rpx;
  padding: 20rpx;
}

.route-cover {
  position: relative;
  flex: 0 0 190rpx;
  height: 168rpx;
  overflow: hidden;
  border-radius: 24rpx;
}

.route-cover::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  background: linear-gradient(180deg, rgba(25, 60, 58, 0), rgba(25, 60, 58, 0.44));
}

.route-cover-img {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.route-cover text {
  display: none;
}

.route-main {
  flex: 1;
  min-width: 0;
}

.route-name {
  color: #193C3A;
  font-size: 31rpx;
  font-weight: 900;
}

.route-sub {
  margin-top: 10rpx;
  color: #315A4E;
  font-size: 24rpx;
  line-height: 1.45;
}

.route-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.route-meta text {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #F6E8D2;
  color: #0F6B67;
  font-size: 21rpx;
  font-weight: 700;
}
