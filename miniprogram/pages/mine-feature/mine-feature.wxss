.mine-feature-page {
  background: #EEF6F4;
}

.feature-hero {
  min-height: 260rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 84% 18%, rgba(255, 253, 248, 0.32), transparent 22%),
    linear-gradient(135deg, #0E6B78 0%, #77B7B0 56%, #C89C3F 100%);
  color: #FBFFFC;
  box-shadow: 0 18rpx 44rpx rgba(26, 74, 70, 0.14);
}

.hero-tag {
  display: inline-flex;
  align-items: center;
  min-height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(251, 255, 252, 0.2);
  color: rgba(251, 255, 252, 0.92);
  font-size: 22rpx;
  font-weight: 700;
}

.feature-title {
  margin-top: 24rpx;
  font-size: 44rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.feature-subtitle {
  margin-top: 14rpx;
  max-width: 600rpx;
  color: rgba(251, 255, 252, 0.9);
  font-size: 26rpx;
  line-height: 1.55;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 26rpx;
}

.hero-chip {
  min-height: 44rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(25, 60, 58, 0.18);
  color: #FBFFFC;
  font-size: 22rpx;
  line-height: 44rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 30rpx 4rpx 16rpx;
  color: #193C3A;
  font-size: 30rpx;
  font-weight: 900;
}

.section-meta {
  color: #607F7A;
  font-size: 23rpx;
  font-weight: 600;
}

.choice-list,
.coupon-list,
.task-list,
.record-list {
  display: grid;
  gap: 18rpx;
}

.choice-card,
.coupon-card,
.task-card,
.record-item,
.points-panel,
.checkin-panel {
  padding: 26rpx;
  border-radius: 20rpx;
  background: #FBFFFC;
  box-shadow: 0 12rpx 32rpx rgba(26, 74, 70, 0.07);
}

.choice-card {
  position: relative;
  border: 2rpx solid transparent;
}

.choice-card.active {
  border-color: #1D7C78;
  background: #F3FBF9;
}

.choice-card.active::after {
  content: "已选";
  position: absolute;
  right: 22rpx;
  top: 22rpx;
  min-width: 58rpx;
  height: 34rpx;
  border-radius: 999rpx;
  background: #1D7C78;
  color: #FBFFFC;
  font-size: 20rpx;
  line-height: 34rpx;
  text-align: center;
}

.choice-title,
.coupon-title,
.task-title,
.record-title {
  padding-right: 76rpx;
  color: #193C3A;
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1.35;
}

.choice-desc,
.coupon-desc,
.task-desc,
.record-desc,
.checkin-desc,
.points-note,
.form-tip {
  margin-top: 10rpx;
  color: #607F7A;
  font-size: 24rpx;
  line-height: 1.5;
}

.choice-price {
  margin-top: 18rpx;
  color: #A7472D;
  font-size: 26rpx;
  font-weight: 900;
}

.form-card {
  margin-top: 22rpx;
  padding: 28rpx;
  border-radius: 22rpx;
}

.form-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 96rpx;
  border-bottom: 2rpx solid #E5F0EC;
}

.field-block {
  padding-top: 24rpx;
}

.field-label {
  color: #193C3A;
  font-size: 27rpx;
  font-weight: 800;
}

.picker-value {
  color: #0F6B67;
  font-size: 27rpx;
  font-weight: 800;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.step-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #DCEDEA;
  color: #0F6B67;
  font-size: 34rpx;
  font-weight: 900;
}

.step-value {
  min-width: 58rpx;
  color: #193C3A;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
}

.form-input,
.form-textarea {
  width: 100%;
  margin-top: 16rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #EEF6F4;
  color: #193C3A;
  font-size: 27rpx;
}

.form-input {
  height: 78rpx;
}

.code-input {
  font-size: 34rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.form-textarea {
  min-height: 190rpx;
  padding-top: 20rpx;
  line-height: 1.5;
}

.form-textarea.small {
  min-height: 150rpx;
}

.form-placeholder {
  color: #8EA6A0;
}

.primary-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1D7C78, #0F6B67);
  color: #FBFFFC;
  font-size: 29rpx;
  font-weight: 900;
  box-shadow: 0 14rpx 30rpx rgba(29, 124, 120, 0.2);
}

.primary-action[disabled] {
  background: #BFD9D3;
  color: #607F7A;
  box-shadow: none;
}

.coupon-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.coupon-card.disabled {
  opacity: 0.55;
}

.coupon-main {
  display: flex;
  align-items: center;
  min-width: 0;
}

.coupon-amount {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  margin-right: 20rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #F4D58E, #C89C3F);
  color: #193C3A;
  font-size: 28rpx;
  font-weight: 900;
}

.coupon-info {
  min-width: 0;
}

.mini-btn,
.coupon-status {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 118rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #1D7C78;
  color: #FBFFFC;
  font-size: 24rpx;
  font-weight: 800;
}

.mini-btn.outline,
.coupon-status {
  border: 2rpx solid #BFD9D3;
  background: #FBFFFC;
  color: #0F6B67;
}

.points-panel {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 24rpx;
  background:
    radial-gradient(circle at 88% 20%, rgba(244, 213, 142, 0.34), transparent 24%),
    #FBFFFC;
}

.points-label {
  color: #607F7A;
  font-size: 24rpx;
  font-weight: 700;
}

.points-value {
  margin-top: 8rpx;
  color: #0F6B67;
  font-size: 58rpx;
  font-weight: 900;
}

.points-note {
  width: 330rpx;
  text-align: right;
}

.task-card,
.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.task-card.done {
  background: #F3FBF9;
}

.task-points {
  flex-shrink: 0;
  min-width: 92rpx;
  color: #A7472D;
  font-size: 25rpx;
  font-weight: 900;
  text-align: right;
}

.checkin-panel {
  margin-top: 24rpx;
  padding: 42rpx 30rpx;
  text-align: center;
}

.checkin-date {
  color: #607F7A;
  font-size: 25rpx;
  font-weight: 700;
}

.checkin-title {
  margin-top: 20rpx;
  color: #193C3A;
  font-size: 42rpx;
  font-weight: 900;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.type-pill {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 16rpx;
  border: 2rpx solid #BFD9D3;
  border-radius: 18rpx;
  background: #FBFFFC;
  color: #315A4E;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
}

.type-pill.active {
  border-color: #1D7C78;
  background: #DCEDEA;
  color: #0F6B67;
}

.record-item {
  min-height: 112rpx;
}

.record-status {
  flex-shrink: 0;
  min-width: 86rpx;
  color: #0F6B67;
  font-size: 24rpx;
  font-weight: 900;
  text-align: right;
}
