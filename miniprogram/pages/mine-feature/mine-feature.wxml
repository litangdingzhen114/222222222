<view class="page page-pad mine-feature-page">
  <view class="feature-hero">
    <view class="hero-tag">{{feature.heroTag || '海林服务'}}</view>
    <view class="feature-title">{{feature.title}}</view>
    <view class="feature-subtitle">{{feature.subtitle}}</view>
    <view class="chip-row">
      <text wx:for="{{feature.chips}}" wx:key="*this" class="hero-chip">{{item}}</text>
    </view>
  </view>

  <block wx:if="{{feature.type === 'coupon'}}">
    <view class="section-head">
      <text>可用权益</text>
      <text class="section-meta">{{coupons.length}} 张</text>
    </view>
    <view class="coupon-list">
      <view wx:for="{{coupons}}" wx:key="id" class="coupon-card {{item.status === '已使用' ? 'disabled' : ''}}">
        <view class="coupon-main">
          <view class="coupon-amount">{{item.amount}}</view>
          <view class="coupon-info">
            <view class="coupon-title">{{item.title}}</view>
            <view class="coupon-desc">{{item.desc}}</view>
          </view>
        </view>
        <button wx:if="{{item.status === '可领取'}}" class="mini-btn" data-id="{{item.id}}" bindtap="onClaimCoupon">领取</button>
        <button wx:elif="{{item.status === '已领取'}}" class="mini-btn outline" data-id="{{item.id}}" bindtap="onUseCoupon">使用</button>
        <view wx:else class="coupon-status">已使用</view>
      </view>
    </view>
  </block>

  <block wx:elif="{{feature.type === 'points'}}">
    <view class="points-panel">
      <view>
        <view class="points-label">当前积分</view>
        <view class="points-value">{{points}}</view>
      </view>
      <view class="points-note">可用于兑换稻鱼宴、讲解和手作体验权益</view>
    </view>

    <view class="section-head">
      <text>积分任务</text>
      <text class="section-meta">点击完成</text>
    </view>
    <view class="task-list">
      <view wx:for="{{tasks}}" wx:key="id" class="task-card {{item.done ? 'done' : ''}}" data-id="{{item.id}}" bindtap="onTaskTap">
        <view>
          <view class="task-title">{{item.title}}</view>
          <view class="task-desc">{{item.desc}}</view>
        </view>
        <view class="task-points">{{item.done ? '已完成' : '+' + item.points}}</view>
      </view>
    </view>
  </block>

  <block wx:elif="{{feature.type === 'checkin'}}">
    <view class="checkin-panel">
      <view class="checkin-date">{{date}}</view>
      <view class="checkin-title">{{checkinDone ? '今天已签到' : '今天还没有签到'}}</view>
      <view class="checkin-desc">签到会增加 5 积分，积分可在海林村权益中心兑换使用。</view>
      <button class="primary-action" disabled="{{checkinDone}}" bindtap="onCheckIn">{{checkinDone ? '今日已完成' : '立即签到 +5积分'}}</button>
    </view>
  </block>

  <block wx:elif="{{feature.type === 'verify'}}">
    <view class="form-card card">
      <view class="field-label">核销码</view>
      <input class="form-input code-input" placeholder="请输入订单或票券核销码" placeholder-class="form-placeholder" value="{{verifyCode}}" bindinput="onVerifyInput" />
      <button class="primary-action" bindtap="onVerifyCode">立即核销</button>
      <view class="form-tip">演示码：HL2026 / HAILIN / 123456</view>
    </view>

    <view class="section-head">
      <text>最近核销</text>
      <text class="section-meta">{{verifications.length}} 条</text>
    </view>
    <view class="record-list">
      <view wx:for="{{verifications}}" wx:key="id" class="record-item">
        <view>
          <view class="record-title">{{item.service}}</view>
          <view class="record-desc">{{item.code}} · {{item.createdAt}}</view>
        </view>
        <view class="record-status">{{item.status}}</view>
      </view>
    </view>
  </block>

  <block wx:elif="{{feature.type === 'cooperation'}}">
    <view class="type-grid">
      <view
        wx:for="{{cooperationTypes}}"
        wx:key="*this"
        class="type-pill {{activeCooperationType === item ? 'active' : ''}}"
        data-type="{{item}}"
        bindtap="onCoopTypeTap"
      >
        {{item}}
      </view>
    </view>

    <view class="form-card card">
      <view class="field-label">合作内容</view>
      <textarea class="form-textarea" placeholder="请说明合作方向、资源、预计时间或团队情况" placeholder-class="form-placeholder" value="{{cooperationContent}}" bindinput="onCooperationInput"></textarea>
      <view class="field-label">联系方式</view>
      <input class="form-input" placeholder="手机号或微信号" placeholder-class="form-placeholder" value="{{contact}}" bindinput="onContactInput" />
      <button class="primary-action" loading="{{submitting}}" bindtap="onSubmitCooperation">提交合作意向</button>
    </view>

    <view class="section-head">
      <text>提交记录</text>
      <text class="section-meta">{{cooperationLeads.length}} 条</text>
    </view>
    <view class="record-list">
      <view wx:for="{{cooperationLeads}}" wx:key="id" class="record-item">
        <view>
          <view class="record-title">{{item.type}}</view>
          <view class="record-desc">{{item.createdAt}}</view>
        </view>
        <view class="record-status">{{item.status}}</view>
      </view>
    </view>
  </block>

  <block wx:else>
    <block wx:if="{{feature.highlights && feature.highlights.length}}">
      <view class="section-head">
        <text>服务亮点</text>
        <text class="section-meta">{{feature.highlights.length}} 项</text>
      </view>
      <view class="feature-highlight-grid">
        <view wx:for="{{feature.highlights}}" wx:key="title" class="feature-highlight-card">
          <view class="feature-highlight-title">{{item.title}}</view>
          <view class="feature-highlight-desc">{{item.desc}}</view>
        </view>
      </view>
    </block>

    <view wx:if="{{feature.process && feature.process.length}}" class="service-flow-card card">
      <view class="service-flow-title">预约流程</view>
      <view wx:for="{{feature.process}}" wx:key="*this" class="flow-step">
        <text class="flow-index">{{index + 1}}</text>
        <text class="flow-copy">{{item}}</text>
      </view>
    </view>

    <view wx:if="{{feature.notes && feature.notes.length}}" class="service-note-card">
      <view class="service-note-title">预订须知</view>
      <view wx:for="{{feature.notes}}" wx:key="*this" class="service-note-item">{{item}}</view>
    </view>

    <view class="section-head">
      <text>选择服务</text>
      <text class="section-meta">{{feature.cards.length}} 项</text>
    </view>
    <view class="choice-list">
      <view
        wx:for="{{feature.cards}}"
        wx:key="title"
        class="choice-card {{selectedIndex === index ? 'active' : ''}}"
        data-index="{{index}}"
        bindtap="onCardTap"
      >
        <view class="choice-title">{{item.title}}</view>
        <view class="choice-desc">{{item.desc}}</view>
        <view class="choice-price">{{item.price}}</view>
      </view>
    </view>

    <view class="form-card card">
      <view class="form-row">
        <text class="field-label">{{feature.formLabels.date}}</text>
        <picker mode="date" value="{{date}}" bindchange="onDateChange">
          <view class="picker-value">{{date}}</view>
        </picker>
      </view>
      <view class="form-row">
        <text class="field-label">{{feature.formLabels.people}}</text>
        <view class="stepper">
          <view class="step-btn" bindtap="onMinus">−</view>
          <view class="step-value">{{people}}</view>
          <view class="step-btn" bindtap="onPlus">＋</view>
        </view>
      </view>
      <view class="field-block">
        <view class="field-label">{{feature.formLabels.contact}}</view>
        <input class="form-input" placeholder="请填写手机号或微信号" placeholder-class="form-placeholder" value="{{contact}}" bindinput="onContactInput" />
      </view>
      <view class="field-block">
        <view class="field-label">{{feature.formLabels.remark}}</view>
        <textarea class="form-textarea small" placeholder="可填写时间段、预算、口味、课程或其他需求" placeholder-class="form-placeholder" value="{{remark}}" bindinput="onRemarkInput"></textarea>
      </view>
      <button class="primary-action" loading="{{submitting}}" bindtap="onSubmitService">{{feature.actionText}}</button>
    </view>

    <view class="section-head">
      <text>我的记录</text>
      <text class="section-meta">{{orders.length}} 条</text>
    </view>
    <view class="record-list">
      <view wx:for="{{orders}}" wx:key="id" class="record-item" data-id="{{item.id}}" bindtap="onOrderRecordTap">
        <view>
          <view class="record-title">{{item.item}}</view>
          <view class="record-desc">{{item.date}} · {{item.people}}人/份 · {{item.createdAt}}</view>
        </view>
        <view class="record-status">{{item.status}}</view>
      </view>
    </view>
  </block>
</view>
