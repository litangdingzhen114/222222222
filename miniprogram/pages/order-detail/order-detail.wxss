.order-detail-page {
  background: #eef6f4;
}

.detail-card,
.section-card {
  padding: 26rpx;
  margin-bottom: 18rpx;
  border: 2rpx solid #e2efec;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 18rpx rgba(26, 74, 70, 0.05);
}

.detail-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.detail-title {
  max-width: 430rpx;
  color: #173c38;
  font-size: 32rpx;
  font-weight: 800;
  line-height: 1.35;
}

.detail-no {
  margin-top: 8rpx;
  color: #78908c;
  font-size: 22rpx;
}

.detail-status {
  flex: 0 0 auto;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  color: #0f6b67;
  background: #e3f2ee;
  font-size: 24rpx;
  font-weight: 800;
}

.detail-status.status-waiting,
.status-hint.status-waiting {
  color: #0f6b67;
  background: #e3f2ee;
}

.detail-status.status-confirmed,
.detail-status.status-shipped,
.status-hint.status-confirmed,
.status-hint.status-shipped {
  color: #125a8a;
  background: #e6f1fb;
}

.detail-status.status-warning,
.status-hint.status-warning {
  color: #95611a;
  background: #fbf0d7;
}

.detail-status.status-done,
.status-hint.status-done {
  color: #2f6b3f;
  background: #e4f3e8;
}

.detail-status.status-muted,
.status-hint.status-muted {
  color: #6d7d79;
  background: #edf1ef;
}

.detail-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
  color: #607b76;
  font-size: 24rpx;
}

.status-hint {
  margin-top: 22rpx;
  padding: 18rpx 20rpx;
  border-radius: 10rpx;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
}

.progress-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 10rpx;
  margin-top: 24rpx;
}

.progress-step {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #8aa19d;
  font-size: 22rpx;
  font-weight: 800;
}

.progress-step::before {
  content: "";
  position: absolute;
  top: 14rpx;
  left: -50%;
  width: 100%;
  height: 4rpx;
  background: #dcebea;
}

.progress-step:first-child::before {
  display: none;
}

.progress-step.done::before,
.progress-step.active::before {
  background: #0f6b67;
}

.progress-dot {
  position: relative;
  z-index: 1;
  width: 24rpx;
  height: 24rpx;
  border: 4rpx solid #dcebea;
  border-radius: 50%;
  background: #fbfffc;
}

.progress-step.done,
.progress-step.active {
  color: #0f6b67;
}

.progress-step.done .progress-dot,
.progress-step.active .progress-dot {
  border-color: #0f6b67;
  background: #0f6b67;
}

.progress-name {
  margin-top: 10rpx;
  line-height: 1.2;
}

.section-title {
  margin-bottom: 18rpx;
  color: #173c38;
  font-size: 30rpx;
  font-weight: 800;
}

.info-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #e7efed;
  color: #34534e;
  font-size: 24rpx;
}

.info-row text:first-child {
  flex: 0 0 150rpx;
  color: #7a908c;
}

.info-row text:last-child {
  flex: 1;
  text-align: right;
}

.copy-btn,
.again-btn,
.cancel-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 20rpx;
  border-radius: 14rpx;
  color: #ffffff;
  background: #0f6b67;
  font-size: 26rpx;
}

.cancel-btn {
  background: #c2412d;
}

.again-btn {
  background: #0f6b67;
}

.section-tip {
  margin-top: 18rpx;
  padding: 18rpx 20rpx;
  border-radius: 10rpx;
  background: #f5faf8;
  color: #607b76;
  font-size: 24rpx;
  line-height: 1.5;
}

.verify-code {
  padding: 24rpx;
  border-radius: 10rpx;
  color: #0f6b67;
  background: #e4f2ef;
  text-align: center;
  font-size: 40rpx;
  font-weight: 800;
  letter-spacing: 0;
}

.verify-note {
  margin-top: 14rpx;
  color: #607b76;
  text-align: center;
  font-size: 24rpx;
}

.timeline-item {
  position: relative;
  display: flex;
  gap: 18rpx;
  padding-bottom: 24rpx;
}

.timeline-dot {
  flex-shrink: 0;
  width: 18rpx;
  height: 18rpx;
  margin-top: 8rpx;
  border-radius: 50%;
  background: #0f6b67;
}

.timeline-title {
  color: #173c38;
  font-size: 26rpx;
  font-weight: 800;
}

.timeline-desc,
.timeline-note,
.timeline-empty {
  margin-top: 6rpx;
  color: #708985;
  font-size: 23rpx;
  line-height: 1.6;
}

.detail-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding-bottom: 8rpx;
}

.detail-actions.single {
  grid-template-columns: 1fr;
}

.detail-actions .again-btn,
.detail-actions .cancel-btn {
  height: 86rpx;
  margin-top: 0;
  font-size: 27rpx;
  font-weight: 900;
}
