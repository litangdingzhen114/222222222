.booking-hero {
  min-height: 250rpx;
  padding: 34rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #1D7C78 0%, #BFD9D3 60%, #607F7A 100%);
  color: #FBFFFC;
  box-shadow: 0 18rpx 44rpx rgba(154, 91, 31, 0.18);
}

.booking-title {
  font-size: 44rpx;
  font-weight: 900;
}

.booking-desc {
  margin-top: 18rpx;
  color: rgba(255, 253, 248, 0.9);
  font-size: 26rpx;
  line-height: 1.6;
}

.booking-card {
  margin-top: 24rpx;
  padding: 28rpx;
}

.form-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 104rpx;
  border-bottom: 2rpx solid #F1E4D1;
}

.form-item.vertical {
  display: block;
  padding: 24rpx 0;
}

.form-label {
  color: #193C3A;
  font-size: 28rpx;
  font-weight: 800;
}

.picker-value {
  color: #0F6B67;
  font-size: 27rpx;
  font-weight: 800;
}

.stepper {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.step-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #DCEDEA;
  color: #0F6B67;
  font-size: 34rpx;
  font-weight: 900;
}

.step-value {
  min-width: 56rpx;
  color: #193C3A;
  font-size: 30rpx;
  font-weight: 900;
  text-align: center;
}

.contact-input {
  height: 80rpx;
  margin-top: 18rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #EEF6F4;
  color: #193C3A;
  font-size: 27rpx;
}

.form-placeholder {
  color: #8EA6A0;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 86rpx;
  margin-top: 30rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1D7C78, #0F6B67);
  color: #FBFFFC;
  font-size: 29rpx;
  font-weight: 900;
}
