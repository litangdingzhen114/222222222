.publish-page {
  background: #EEF6F4;
}

.publish-hero {
  min-height: 220rpx;
  padding: 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 82% 20%, rgba(244, 213, 142, 0.34), transparent 26%),
    linear-gradient(135deg, #0F6B67 0%, #77B7B0 62%, #315A4E 100%);
  color: #FBFFFC;
  box-shadow: 0 18rpx 44rpx rgba(26, 74, 70, 0.14);
}

.publish-title {
  font-size: 42rpx;
  font-weight: 900;
}

.publish-sub {
  margin-top: 16rpx;
  color: rgba(251, 255, 252, 0.88);
  font-size: 26rpx;
  line-height: 1.55;
}

.publish-card {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 22rpx;
}

.field-block {
  margin-bottom: 24rpx;
}

.field-label {
  color: #193C3A;
  font-size: 27rpx;
  font-weight: 800;
}

.form-input,
.form-textarea,
.topic-picker {
  width: 100%;
  margin-top: 14rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #EEF6F4;
  color: #193C3A;
  font-size: 27rpx;
}

.form-input,
.topic-picker {
  height: 78rpx;
  line-height: 78rpx;
}

.topic-picker {
  color: #0F6B67;
  font-weight: 800;
}

.form-textarea {
  min-height: 260rpx;
  padding-top: 20rpx;
  line-height: 1.55;
}

.form-placeholder {
  color: #8EA6A0;
}

.image-uploader {
  position: relative;
  width: 100%;
  height: 280rpx;
  margin-top: 14rpx;
  overflow: hidden;
  border: 2rpx dashed #BFD9D3;
  border-radius: 20rpx;
  background: #F6FBF9;
}

.chosen-image {
  width: 100%;
  height: 100%;
}

.upload-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100%;
  color: #607F7A;
  font-size: 25rpx;
  font-weight: 700;
}

.upload-plus {
  margin-bottom: 8rpx;
  color: #0F6B67;
  font-size: 52rpx;
  line-height: 1;
}

.submit-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1D7C78, #0F6B67);
  color: #FBFFFC;
  font-size: 29rpx;
  font-weight: 900;
}
