<view class="page page-pad user-list-page">
  <view class="list-hero">
    <view class="list-title">{{meta.title}}</view>
    <view class="list-sub">{{meta.subtitle}}</view>
  </view>

  <view wx:if="{{items.length}}" class="content-list">
    <view wx:for="{{items}}" wx:key="id" class="content-item" data-url="{{item.targetUrl}}" bindtap="onItemTap">
      <view class="item-topic">{{item.topic || meta.title}}</view>
      <view class="item-title">{{item.title}}</view>
      <view class="item-summary">{{item.summary}}</view>
      <view class="item-meta">{{item.createdAt || '已收藏'}}</view>
    </view>
  </view>

  <view wx:else class="empty-card">
    <view class="empty-title">这里还没有内容</view>
    <view class="empty-desc">去逛逛海林村，喜欢的景点、路线和游记会回到这里。</view>
  </view>

  <button class="primary-action" bindtap="onPrimaryTap">{{meta.actionText}}</button>
</view>
