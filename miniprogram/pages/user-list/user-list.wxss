.user-list-page {
  background: #EEF6F4;
}

.list-hero {
  padding: 32rpx;
  border-radius: 28rpx;
  background:
    radial-gradient(circle at 88% 20%, rgba(244, 213, 142, 0.3), transparent 24%),
    linear-gradient(135deg, #0E6B78, #77B7B0);
  color: #FBFFFC;
  box-shadow: 0 18rpx 44rpx rgba(26, 74, 70, 0.14);
}

.list-title {
  font-size: 42rpx;
  font-weight: 900;
}

.list-sub {
  margin-top: 14rpx;
  color: rgba(251, 255, 252, 0.88);
  font-size: 26rpx;
  line-height: 1.55;
}

.content-list {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.content-item,
.empty-card {
  padding: 26rpx;
  border-radius: 20rpx;
  background: #FBFFFC;
  box-shadow: 0 12rpx 32rpx rgba(26, 74, 70, 0.07);
}

.item-topic {
  display: inline-flex;
  align-items: center;
  min-height: 38rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  background: #DCEDEA;
  color: #0F6B67;
  font-size: 21rpx;
  font-weight: 800;
}

.item-title {
  margin-top: 16rpx;
  color: #193C3A;
  font-size: 31rpx;
  font-weight: 900;
  line-height: 1.35;
}

.item-summary,
.empty-desc {
  margin-top: 10rpx;
  color: #607F7A;
  font-size: 25rpx;
  line-height: 1.55;
}

.item-meta {
  margin-top: 16rpx;
  color: #A7472D;
  font-size: 23rpx;
  font-weight: 800;
}

.empty-card {
  margin-top: 24rpx;
  min-height: 220rpx;
  text-align: center;
}

.empty-title {
  margin-top: 30rpx;
  color: #193C3A;
  font-size: 31rpx;
  font-weight: 900;
}

.primary-action {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  margin-top: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1D7C78, #0F6B67);
  color: #FBFFFC;
  font-size: 29rpx;
  font-weight: 900;
}
