.real-player-wrap {
  position: relative;
  height: 420rpx;
  overflow: hidden;
  border-radius: 16rpx;
  background: #0F4F4B;
  box-shadow: 0 6rpx 18rpx rgba(26, 74, 70, 0.08);
}

.real-player {
  width: 100%;
  height: 100%;
  overflow: hidden;
  border-radius: 0;
  background: #0F4F4B;
}

.live-time-badge {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  z-index: 20;
  height: 58rpx;
  padding: 0 18rpx;
  border-radius: 10rpx;
  background: rgba(15, 79, 75, 0.78);
  color: #FBFFFC;
  line-height: 58rpx;
}

.live-time-dot {
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #D94B35;
}

.live-time-text {
  display: inline-block;
  color: #FBFFFC;
  font-size: 23rpx;
  font-weight: 800;
}

.mock-player {
  position: relative;
  height: 420rpx;
  overflow: hidden;
  border-radius: 16rpx;
  box-shadow: 0 6rpx 18rpx rgba(26, 74, 70, 0.08);
}

.mock-cover {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.mock-player::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 46%;
  background: linear-gradient(180deg, rgba(25, 60, 58, 0), rgba(25, 60, 58, 0.6));
}

.live-status {
  position: absolute;
  left: 22rpx;
  top: 22rpx;
  z-index: 2;
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  border-radius: 10rpx;
  background: rgba(15, 79, 75, 0.66);
  color: #FBFFFC;
  font-size: 22rpx;
  font-weight: 700;
}

.status-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #D94B35;
}

.mock-play {
  position: absolute;
  left: 50%;
  top: 50%;
  z-index: 2;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 108rpx;
  height: 108rpx;
  border-radius: 16rpx;
  background: rgba(251, 255, 252, 0.84);
  color: #0F6B67;
  font-size: 42rpx;
  transform: translate(-50%, -50%);
}

.mock-caption {
  position: absolute;
  left: 24rpx;
  bottom: 26rpx;
  z-index: 2;
  color: #FBFFFC;
  font-size: 26rpx;
  font-weight: 700;
}

.mock-word {
  display: none;
}

.live-info-card {
  margin-top: 22rpx;
  padding: 26rpx;
}

.live-name {
  color: #193C3A;
  font-size: 34rpx;
  font-weight: 800;
}

.online {
  margin-top: 10rpx;
  color: #A7472D;
  font-size: 24rpx;
  font-weight: 800;
}

.live-desc {
  margin-top: 16rpx;
  color: #315A4E;
  font-size: 27rpx;
  line-height: 1.65;
}

.nearby-row {
  display: flex;
  gap: 18rpx;
}

.nearby-card {
  flex: 1;
  overflow: hidden;
}

.nearby-img {
  position: relative;
  overflow: hidden;
  height: 146rpx;
  border-radius: 16rpx 16rpx 0 0;
}

.nearby-img::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 62%;
  background: linear-gradient(180deg, rgba(25, 60, 58, 0), rgba(25, 60, 58, 0.56));
}

.nearby-photo {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.nearby-img text {
  display: none;
}

.nearby-title {
  padding: 16rpx;
  color: #193C3A;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}
