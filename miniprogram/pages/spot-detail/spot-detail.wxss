.spot-detail-page {
  padding-bottom: 150rpx;
}

.spot-hero-swiper {
  height: 420rpx;
}

.spot-hero {
  position: relative;
  height: 420rpx;
}

.spot-hero-img,
.nearby-photo {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
}

.spot-hero::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 42%;
  background: linear-gradient(180deg, rgba(58, 42, 26, 0), rgba(58, 42, 26, 0.34));
}

.spot-hero-word {
  display: none;
}

.detail-content {
  margin-top: -34rpx;
  padding: 0 24rpx;
}

.detail-card,
.intro-card {
  position: relative;
  z-index: 2;
  padding: 26rpx;
}

.intro-card {
  margin-top: 22rpx;
}

.detail-title-row {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-name {
  color: #193C3A;
  font-size: 42rpx;
  font-weight: 900;
}

.detail-distance {
  color: #1D7C78;
  font-size: 24rpx;
  font-weight: 800;
}

.detail-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 18rpx;
}

.detail-tags text {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #F6E8D2;
  color: #0F6B67;
  font-size: 22rpx;
  font-weight: 700;
}

.info-row {
  display: flex;
  justify-content: space-between;
  margin-top: 22rpx;
  color: #315A4E;
  font-size: 26rpx;
}

.info-label {
  color: #607F7A;
}

.info-value {
  color: #193C3A;
  font-weight: 700;
}

.intro-card section-title {
  display: block;
  margin-top: -20rpx;
}

.intro-text {
  color: #5B422B;
  font-size: 27rpx;
  line-height: 1.75;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.detail-action {
  flex: 1;
}

.highlight-list {
  display: grid;
  gap: 16rpx;
  margin-bottom: 22rpx;
}

.highlight-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 22rpx;
}

.highlight-index {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #DCEDEA;
  color: #0F6B67;
  font-size: 23rpx;
  font-weight: 900;
}

.highlight-copy {
  flex: 1;
  color: #315A4E;
  font-size: 25rpx;
  line-height: 1.55;
}

.tips-card {
  margin: 6rpx 0 24rpx;
  padding: 26rpx;
  background: #F9F2E6;
}

.tips-title {
  color: #5B422B;
  font-size: 29rpx;
  font-weight: 900;
}

.tip-row {
  display: flex;
  gap: 14rpx;
  margin-top: 18rpx;
  color: #5B422B;
  font-size: 24rpx;
  line-height: 1.55;
}

.tip-row text {
  flex-shrink: 0;
  width: 10rpx;
  height: 10rpx;
  margin-top: 14rpx;
  border-radius: 50%;
  background: #C89C3F;
}

.service-link-list {
  display: grid;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.service-link-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx;
}

.service-link-title {
  color: #193C3A;
  font-size: 28rpx;
  font-weight: 900;
}

.service-link-desc {
  margin-top: 8rpx;
  color: #607F7A;
  font-size: 24rpx;
  line-height: 1.45;
}

.service-link-arrow {
  flex-shrink: 0;
  color: #0F6B67;
  font-size: 46rpx;
  font-weight: 300;
}

.nearby-row {
  display: flex;
  gap: 18rpx;
  padding-bottom: 20rpx;
}

.nearby-card {
  flex: 1;
  overflow: hidden;
}

.nearby-img {
  position: relative;
  height: 142rpx;
  border-radius: 28rpx 28rpx 0 0;
}

.nearby-img text {
  display: none;
}

.nearby-title {
  padding: 16rpx;
  color: #193C3A;
  font-size: 24rpx;
  font-weight: 800;
  text-align: center;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 18rpx 24rpx calc(18rpx + env(safe-area-inset-bottom));
  background: #FBFFFC;
  box-shadow: 0 -10rpx 28rpx rgba(112, 76, 34, 0.08);
}

.bottom-mini {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 132rpx;
  height: 74rpx;
  border-radius: 999rpx;
  background: #F6E8D2;
  color: #0F6B67;
  font-size: 25rpx;
  font-weight: 800;
}

.bottom-mini.active {
  background: #BFD9D3;
}

.bottom-main {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  height: 78rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #1D7C78, #0F6B67);
  color: #FBFFFC;
  font-size: 28rpx;
  font-weight: 900;
}
