.product-card {
  width: 206rpx;
  flex: 0 0 206rpx;
}

.product-img {
  position: relative;
  width: 206rpx;
  height: 176rpx;
  border-radius: 24rpx;
}

.product-cover {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  border-radius: 24rpx;
}

.price-tag {
  position: absolute;
  left: 12rpx;
  bottom: 12rpx;
  padding: 7rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(15, 79, 75, 0.74);
  color: #FBFFFC;
  font-size: 20rpx;
  font-weight: 700;
}

.product-icon {
  display: none;
}

.product-title {
  margin-top: 12rpx;
  color: #193C3A;
  font-size: 24rpx;
  line-height: 1.35;
}
