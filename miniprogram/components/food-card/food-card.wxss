.food-card {
  display: flex;
  gap: 30rpx;
  margin-bottom: 30rpx;
  padding: 0;
  border-radius: 0;
  background: transparent;
  box-shadow: none;
}

.food-cover {
  position: relative;
  flex: 0 0 200rpx;
  height: 170rpx;
  border-radius: 16rpx;
}

.food-cover-img {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  border-radius: 16rpx;
}

.food-cover-icon {
  display: none;
}

.food-main {
  flex: 1;
  min-width: 0;
}

.food-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.food-name {
  color: #0F4F4B;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 1.25;
}

.food-distance {
  flex: 0 0 auto;
  color: #315A4E;
  font-size: 24rpx;
}

.food-meta {
  margin-top: 10rpx;
  color: #315A4E;
  font-size: 27rpx;
}

.food-desc {
  margin-top: 10rpx;
  color: #315A4E;
  font-size: 26rpx;
  line-height: 1.45;
}

.food-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.food-tag {
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #E2F0EC;
  color: #0F6B67;
  font-size: 20rpx;
}
