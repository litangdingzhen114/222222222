}

.ph-ricefish {
  background: linear-gradient(135deg, #0F6B67 0%, #E6D69D 52%, #D94B35 100%);
}

.ph-stone {
  background: linear-gradient(135deg, #355E5D 0%, #8EA6A0 50%, #D7C7AC 100%);
}

.ph-overseas {
  background: linear-gradient(135deg, #325B5A 0%, #C89C3F 54%, #A7472D 100%);
}

.ph-product-fish {
  background: linear-gradient(135deg, #0F6B67 0%, #E6D69D 52%, #D94B35 100%);
}

.ph-product-stone {
  background: linear-gradient(135deg, #355E5D 0%, #8EA6A0 50%, #D7C7AC 100%);
}

.safe-bottom {
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
}
