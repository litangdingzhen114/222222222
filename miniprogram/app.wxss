}

.ph-live {
  background: linear-gradient(135deg, #0F6B67 0%, #A9D2CB 52%, #315A4E 100%);
}

.ph-route {
  background: linear-gradient(135deg, #0F4F4B 0%, #77B7B0 54%, #E8DDD0 100%);
}

.ph-product-rice {
  background: linear-gradient(135deg, #E6D69D, #1D7C78);
}

.ph-product-sachet {
