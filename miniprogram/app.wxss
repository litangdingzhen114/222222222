page {
  min-height: 100%;
  background: #EEF6F4;
  color: #193C3A;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 28rpx;
}

view,
text,
scroll-view,
swiper,
swiper-item,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  margin: 0;
  padding: 0;
  background: transparent;
  color: inherit;
  font: inherit;
  line-height: 1;
}

button::after {
  border: 0;
}

.page {
  min-height: 100vh;
  background: #EEF6F4;
  padding-bottom: 40rpx;
}

.page-pad {
  padding: 24rpx 24rpx 40rpx;
}

.card {
  background: #FBFFFC;
  border-radius: 28rpx;
  box-shadow: 0 16rpx 40rpx rgba(26, 74, 70, 0.08);
}

.muted {
  color: #607F7A;
}

.primary-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 76rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  background: #0F6B67;
  color: #FBFFFC;
  font-size: 28rpx;
  font-weight: 600;
  box-shadow: 0 12rpx 28rpx rgba(29, 124, 120, 0.24);
}

.outline-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 72rpx;
  padding: 0 28rpx;
  border: 2rpx solid #BFD9D3;
  border-radius: 999rpx;
  background: #FBFFFC;
  color: #0F6B67;
  font-size: 26rpx;
  font-weight: 600;
}

.image-ph {
  position: relative;
  overflow: hidden;
  border-radius: 24rpx;
  background: #DCEDEA;
}

.image-ph .ph-icon {
  position: absolute;
  right: 20rpx;
  bottom: 16rpx;
  color: rgba(251, 255, 252, 0.84);
  font-size: 56rpx;
  line-height: 1;
}

